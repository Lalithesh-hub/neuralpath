# ─── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/neuralpath?schema=public"

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── ANTHROPIC AI ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ─── RAZORPAY ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# ─── EMAIL (Nodemailer via Gmail) ─────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: myaccount.google.com → Security → App Passwords
# 3. Generate a 16-character App Password for "Mail"
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── GOOGLE OAUTH ─────────────────────────────────────
# 1. Go to: console.cloud.google.com
# 2. Create project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

